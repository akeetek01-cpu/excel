{
  "openapi": "3.0.0",
  "info": {
    "title": "excel API",
    "version": "1.0.0",
    "description": "API docs for the excel project"
  },
  "paths": {
    "/api/dashboard": {
      "get": {
        "summary": "Protected API",
        "responses": {
          "200": {"description": "Success"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/register": {
      "post": {
        "summary": "Register a new user (Firebase)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                },
                "required": ["name", "email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "User registered successfully" },
          "400": { "description": "Validation error" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/api/users": {
      "get": {
        "summary": "Get all users (Firebase)",
        "responses": {
          "200": { "description": "A list of users" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/api/login": {
      "post": {
        "summary": "Login with email and password (Firebase)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful" },
          "400": { "description": "Validation error" },
          "401": { "description": "Invalid credentials" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/api/changePassword": {
    "post": {
      "summary": "Change user password",
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "email": {
                  "type": "string",
                  "example": "t.solley@excel.co.nz"
                },
                "oldPassword": {
                  "type": "string",
                  "example": "t.solley"
                },
                "newPassword": {
                  "type": "string",
                  "example": "Welcome@123"
                }
              },
              "required": [
                "email",
                "oldPassword",
                "newPassword"
              ]
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Password updated successfully"
        },
        "400": {
          "description": "Email, old password and new password are required"
        },
        "401": {
          "description": "Invalid email or old password"
        },
        "404": {
          "description": "Users not found"
        },
        "500": {
          "description": "Server error"
        }
      }
    }
  }
  }
}
